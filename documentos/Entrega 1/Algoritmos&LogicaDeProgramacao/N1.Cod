// variável que controla a energia do jogador
int energia = 100;

// variável que armazena a pontuação
int pontos = 0;

// variável para guardar respostas (sim/não)
string SN = "";

// loop principal do jogo (roda enquanto tiver energia)
while (energia > 0)
{
    // ================= FASE 1 =================
    Console.WriteLine("=== FASE 1 ===");

    // introdução da história
    Console.WriteLine("Você acorda no laboratório, sozinho(a)! Deseja tentar sair? (sim/não)");

    // mostra status do jogador
    Console.WriteLine("Energia: " + energia + " | Pontos: " + pontos);

    // lê resposta do jogador
    SN = Console.ReadLine();

    // verifica se o jogador respondeu "sim"
    if (SN.ToLower() == "sim" || SN.ToLower() == "s")
    {
        // ganha pontos por decisão positiva
        pontos += 25;

        Console.WriteLine("Você foi até a porta.");

        // nova decisão
        Console.WriteLine("Deseja pedir ajuda escrevendo no papel? (sim/não)");
        SN = Console.ReadLine();

        if (SN.ToLower() == "sim" || SN.ToLower() == "s")
        {
            // ganha mais pontos
            pontos += 25;

            Console.WriteLine("Ninguém viu... mas você tentou.");
        }
        else
        {
            // perde energia por decisão ruim
            energia -= 20;

            Console.WriteLine("Você perdeu tempo.");
            Console.WriteLine("Energia: " + energia);
        }
    }
    else
    {
        // perde energia se decidir não agir
        energia -= 30;

        Console.WriteLine("Você decidiu não agir.");
        Console.WriteLine("Energia: " + energia);
    }

    // verifica se o jogador ficou sem energia
    if (energia <= 0) break;

    // ================= FASE 2 =================
    Console.WriteLine("\n=== FASE 2 ===");

    // desafio com pergunta
    Console.WriteLine("Você encontra um computador com senha.");
    Console.WriteLine("Pergunta: Quanto é 5 + 3?");

    string resposta = Console.ReadLine();

    // verifica se acertou
    if (resposta == "8")
    {
        // ganha pontos
        pontos += 25;

        Console.WriteLine("Senha correta!");
    }
    else
    {
        // perde energia
        energia -= 20;

        Console.WriteLine("Senha incorreta!");
        Console.WriteLine("Energia: " + energia);
    }

    // verifica energia novamente
    if (energia <= 0) break;

    // ================= FASE 3 =================
    Console.WriteLine("\n=== FASE 3 ===");

    // último desafio
    Console.WriteLine("Você chegou na porta final.");
    Console.WriteLine("Digite a palavra-chave (dica: liberdade)");

    resposta = Console.ReadLine();

    // verifica resposta correta
    if (resposta.ToLower() == "liberdade")
    {
        // ganha pontos finais
        pontos += 25;

        Console.WriteLine("Porta destrancada!");
        Console.WriteLine("Você escapou!");

        // mostra pontuação final
        Console.WriteLine("Pontuação final: " + pontos);

        // encerra o jogo (vitória)
        break;
    }
    else
    {
        // perde energia se errar
        energia -= 30;

        Console.WriteLine("Senha errada!");
        Console.WriteLine("Energia: " + energia);
    }

    // verifica se perdeu
    if (energia <= 0)
    {
        Console.WriteLine("Você ficou sem energia... Game Over!");
        break;
    }

    // opção de continuar ou desistir
    Console.WriteLine("Deseja continuar ou desistir? (sim = continuar / não = desistir)");
    SN = Console.ReadLine();

    // se o jogador desistir
    if (SN.ToLower() == "não" || SN.ToLower() == "n")
    {
        Console.WriteLine("Você desistiu e vai esperar alguém abrir.");
        break;
    }
}